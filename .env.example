# =============================================================================
# Tactical-Infinity (Tethical) — environment template
# Copy to .env for local dev. Set the same keys in Vercel + Railway dashboards.
# =============================================================================

# ── Vercel (client / VITE_* — baked at build time) ───────────────────────────

# Grudge R2 CDN for models, textures, Toon-RTS FBX, animations
VITE_USE_ASSETS_CDN=true
VITE_ASSETS_CDN_URL=https://assets.grudge-studio.com
VITE_OBJECTSTORE_URL=https://objectstore.grudge-studio.com

# Canonical public origin (SSO redirect_uri). Production: water.grudge-studio.com
VITE_APP_ORIGIN=https://water.grudge-studio.com
VITE_AUTH_GATEWAY_URL=https://id.grudge-studio.com

# Deep-link handoff to production Grudge Warlords shell
VITE_WARLORDS_URL=https://grudgewarlords.com

# Optional: force API base (leave unset — use same-origin /api via vercel.json rewrites)
# VITE_GRUDGE_API_URL=

# ── Railway (Tactical-Infinity game server) ──────────────────────────────────

NODE_ENV=production
PORT=5000

# Tactical-specific Postgres (battles, roster, harvest sim, meshy jobs)
DATABASE_URL=postgresql://user:pass@host:5432/tactical_infinity

# Comma-separated browser origins allowed to call Railway directly (dev / WS)
CORS_ORIGINS=http://localhost:5000,http://localhost:5173,https://water.grudge-studio.com,https://tactical-infinity.vercel.app,https://tethical.grudge-studio.com,https://*.vercel.app

# Optional AI ship/captain generation
# MESHY_API_KEY=

# Optional Replit object-storage CDN fallback (legacy — prefer R2 in production)
# REPLIT_OBJECT_STORAGE_BUCKET=

# ── GrudgeBuilder Railway (characters / island / wallet — NOT in this repo) ──
# Characters SSOT lives on Grudge-Builder Postgres. Vercel rewrites /api/characters
# → grudge-api-production-0d46.up.railway.app. No env needed in Tactical-Infinity
# unless you run GrudgeBuilder locally.